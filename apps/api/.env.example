# Server
API_PORT=4000
SWAGGER_ENABLED=true

# Database (Local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/happynachbar?schema=public

# Auth
JWT_SECRET=CHANGE_ME_DEV_ONLY
JWT_EXPIRES_IN=672h

# Web / CORS
WEB_URL=http://localhost:3000

# Email tokens
EMAIL_TOKEN_SECRET=CHANGE_ME_DEV_ONLY
EMAIL_TOKEN_EXPIRES_IN=24h

# Uploads (S3 / CloudFront)
AWS_REGION=eu-central-1
S3_BUCKET=__YOUR_BUCKET_NAME__
CLOUDFRONT_BASE_URL=__YOUR_CLOUDFRONT_URL__

AWS_ACCESS_KEY_ID=__YOUR_AWS_ACCESS_KEY_ID__
AWS_SECRET_ACCESS_KEY=__YOUR_AWS_SECRET_ACCESS_KEY__
UPLOAD_PRESIGN_EXPIRES_SECONDS=600